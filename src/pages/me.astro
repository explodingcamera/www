---
import Link from "../components/Link.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About Me">
  <div class="about">
    <h1>about me</h1>
    <p>
      I'm a software engineer based in Stuttgart, working on backend systems,
      Rust, WebAssembly, and open-source software.
      <br />
      <br />
      My work focuses on reliable, high-performance software with clear abstractions
      and maintainable architecture. I'm especially interested in systems, infrastructure,
      tooling, and self-hosted platforms.
      <br />
      <br />
      Outside of my professional work, I build open-source software around WebAssembly,
      privacy-focused analytics, and maintain various libraries.<br />
      <br />
      <br />

      Feel free to reach out
      <Link href="mailto:hi@henrygressmann.de">by email</Link> or check out my
      <Link href="/static/cv-henry-gressmann.pdf">CV</Link>.
    </p>
  </div>
</MainLayout>

<style>
  .about {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;

    h1 {
      font-size: 3em;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      background-image: linear-gradient(270deg, #ff0000, #008cff, #50ff00);
      background-size: 600% 600%;
      background-position: 79% 50%;
    }

    p {
      font-size: 1.4rem;
      line-height: 1.5;
      max-width: 38rem;
      a {
        white-space: nowrap;
      }

      > span {
        color: white;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        margin: 0.1rem 0.2rem;
        backdrop-filter: blur(1px);
        box-shadow: 0px 0px 7px 0px rgb(0 0 0 / 35%);
        white-space: nowrap;

        &:nth-of-type(1) {
          background-image: linear-gradient(270deg, #0b7261c1, #23d1b4c1);
        }

        /* &:nth-of-type(2) {
          background-image: linear-gradient(270deg, #3179c6c1, #3179c6c1);
        }

        &:nth-of-type(3) {
          background-image: linear-gradient(270deg, #61dafbc1, #45b4d3c1);
        } */

        &:nth-of-type(2) {
          background-image: linear-gradient(270deg, #f0db4fc1, #f0db4fc1);
        }
      }
    }
  }
</style>

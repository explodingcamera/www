---
import ProjectCard from "../components/ProjectCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { projects } from "../projects";
---

<MainLayout title="My Work">
  <div class="container">
    <masonry-grid>
      {projects.map((p) => <ProjectCard {...p} />)}
    </masonry-grid>
  </div>
</MainLayout>
